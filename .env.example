# Optional Mission Control server tuning (copy to .env.local for Next.js)
# PORT=3000

# Hermes data directory (must match the Hermes agent)
# HERMES_HOME=/home/you/.hermes

# Mission Control JSON data root (missions, templates, operations, stories).
# Default: $HOME/mission-control/data (matches nested Hermes cron mission updates).
# MC_DATA_DIR=/home/you/mission-control/data
# (alias) MISSION_CONTROL_DATA_DIR=

# Comma-separated extra dev origins for next.config (e.g. http://192.168.1.10:3000)
# MC_ALLOWED_DEV_ORIGINS=

# Require API key for mutating routes (cron, missions, config, agent files, operations)
# MC_API_KEY=

# Block all writes (GET still works)
# MC_READ_ONLY=1

# Force-disable POST /api/update even in development
# MC_ENABLE_DEPLOY_API=false

# Git branch for deploy/update API and scripts/update.sh (default main)
# MC_UPDATE_GIT_BRANCH=dev

# Edition: simple (OSS default) or commercial (full UI + template library).
# Put these in .env.local — typing `MC_EDITION=simple` in the shell without `export` does not apply to `npm run build` or `npm run dev`.
# NEXT_PUBLIC_MC_EDITION is fixed when you run `next build` or start dev (from .env.local).
# MC_EDITION=simple
# NEXT_PUBLIC_MC_EDITION=simple
